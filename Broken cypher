def decrypt_caesar_ascii(cipher_text, key):
    result = ''
    for char in cipher_text:
        if 32 <= ord(char) <= 126:  # Printable ASCII range
            shifted = (ord(char) - 32 - key) % 95 + 32
            result += chr(shifted)
        else:
            result += char
    return result

